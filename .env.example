# SERP Scraper Configuration
# Copy this file to .env and customize as needed
# All settings are optional with sensible defaults

# ===========================================
# PROXY CONFIGURATION
# ===========================================

# DataImpulse Proxy (recommended)
# Get your credentials from https://dataimpulse.com/
# Protocol: http (port 823) or socks5 (port 824) for rotating
# Sticky proxies: ports 10000-20000
SERP_DATAIMPULSE_GATEWAY=http://gw.dataimpulse.com
SERP_DATAIMPULSE_USER=your_dataimpulse_username
SERP_DATAIMPULSE_PASS=your_dataimpulse_password
SERP_DATAIMPULSE_PROTOCOL=http  # "http" or "socks5"
SERP_DATAIMPULSE_COUNTRY=  # Optional: country code like "us", "de", "gb"
SERP_DATAIMPULSE_SESSID=  # Optional: session ID for sticky proxy (binds IP for ~30 min)
SERP_DATAIMPULSE_SESSTTL=  # Optional: session TTL in minutes (1-120) for sticky proxies

# Alternative: Custom Proxy Servers (comma-separated for multiple)
# Format: http://user:pass@host:port or socks5://host:port
# Example: http://user:pass@proxy1.example.com:8080,socks5://proxy2.example.com:1080
SERP_CUSTOM_PROXIES=http://user:pass@proxy.example.com:8080

# Proxy selection strategy
# "random" - randomly select from proxy list (default)
# "dataimpulse_first" - prefer DataImpulse, fallback to custom proxies
SERP_PROXY_STRATEGY=dataimpulse_first

# ===========================================
# CACHE CONFIGURATION
# ===========================================

# Enable/disable caching
SERP_CACHE_ENABLED=true

# Cache directory (default: .cache/serp)
SERP_CACHE_DIR=.cache/serp

# Cache time-to-live in seconds (default: 86400 = 24 hours)
SERP_CACHE_TTL=86400

# ===========================================
# BROWSER CONFIGURATION
# ===========================================

# Chrome/Chromium executable path (optional - nodriver auto-detects by default)
# CHROME_PATH=/snap/bin/chromium

# ===========================================
# SEARCH CONFIGURATION
# ===========================================

# Default search source: "google", "bing", or "auto" (google first, bing fallback)
SERP_DEFAULT_SOURCE=auto

# Browser headless mode: "true" or "false" (default: false)
SERP_HEADLESS=false

# Request timeout in seconds (default: 30, min: 5, max: 120)
SERP_TIMEOUT=30

# ===========================================
# RETRY CONFIGURATION
# ===========================================

# Maximum retry attempts (default: 3, max: 10)
SERP_MAX_RETRIES=3

# Retry delay range in seconds (default: 0.5 - 2.0)
SERP_RETRY_DELAY_MIN=0.5
SERP_RETRY_DELAY_MAX=2.0

# Use exponential backoff: "true" or "false" (default: false)
SERP_EXPONENTIAL_BACKOFF=false

# ===========================================
# LOGGING
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: WARNING)
SERP_LOG_LEVEL=WARNING

# Enable debug mode (same as SERP_LOG_LEVEL=DEBUG)
SERP_DEBUG=false

# ===========================================
# USER AGENTS
# ===========================================

# Custom user agent (optional, defaults to rotating Chrome/Firefox agents)
# SERP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
